{
  "name": "@tetsup/web2d",
  "version": "0.0.11",
  "license": "MIT",
  "author": "tetsup",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "url": "https://github.com/tetsup/web2d"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "tsup",
    "build:test": "pnpm build && vite build",
    "dev": "pnpm build && vite",
    "preview": "pnpm build && vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "pnpm build && playwright test",
    "lint": "oxlint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.5.0",
    "@vitest/browser-playwright": "4.1.2",
    "@vitest/coverage-v8": "4.1.2",
    "eslint": "^10.2.0",
    "jsdom": "^27.4.0",
    "oxlint": "^1.58.0",
    "playwright": "^1.59.1",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.3",
    "vitest": "4.1.2"
  }
}
