{
  "name": "@tetsup/web2d",
  "version": "0.0.2",
  "license": "MIT",
  "author": "tetsup",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "url": "https://github.com/tetsup/web2d"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "pnpm run build:lib",
    "build:worker": "tsc -p tsconfig.worker.json",
    "build:lib": "tsdx build && pnpm run build:worker",
    "build:test": "vite build",
    "dev": "vite",
    "watch:lib": "tsdx watch",
    "preview:test": "vite preview",
    "dev:all": "concurrently \"pnpm:watch:lib\" \"pnpm:dev\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "lint": "tsdx lint",
    "format": "tsdx format",
    "format:check": "tsdx format --check",
    "typecheck": "tsdx typecheck",
    "prepublishOnly": "pnpm run build"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.5.0",
    "@vitest/browser-playwright": "4.1.2",
    "@vitest/coverage-v8": "4.1.2",
    "bunchee": "^6.9.4",
    "eslint": "^10.2.0",
    "eslint-plugin-prettier": "^5.5.5",
    "jsdom": "^27.4.0",
    "playwright": "^1.59.1",
    "prettier": "^3.8.1",
    "tsdx": "^2.0.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.3",
    "vitest": "4.1.2"
  }
}
